# Cargo build artifacts
target/
**/target/

# Cargo lock — keep at workspace root and at the root of each example
# (each example is a binary, so committing its lockfile is the
# convention). Ignore lockfiles only inside library subcrates.
crates/**/Cargo.lock

# IDE / editor
.idea/
.vscode/
*.iml
*.swp
.DS_Store

# Claude Code agent state (per-checkout local working directory)
.claude/

# Env files (never commit secrets)
.env
.env.*.local
*.env.local

# Coverage
*.profraw
coverage/
tarpaulin-report.html
lcov.info
