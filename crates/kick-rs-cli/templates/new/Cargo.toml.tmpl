[package]
name        = "{{project_name}}"
version     = "0.1.0"
edition     = "2021"
publish     = false

[dependencies]
kick-rs = { version = "0.1.0-alpha.1", features = ["macros", "config"] }

axum    = "0.7"
tokio   = { version = "1", features = ["macros", "rt-multi-thread", "signal"] }
serde   = { version = "1", features = ["derive"] }
serde_json = "1"
tracing = "0.1"
tracing-subscriber = { version = "0.3", features = ["env-filter"] }
