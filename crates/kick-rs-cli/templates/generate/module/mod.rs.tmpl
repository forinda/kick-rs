//! `{{module_name}}` module — generated by `cargo kick g module`.

pub mod handlers;

use kick_rs::{define_module, Module};

/// Build the `{{module_name}}` module. Routes are mounted under `/{{module_name}}`.
///
/// Register on `bootstrap()` in `main.rs`:
///
/// ```ignore
/// .module({{module_name_snake}}::define())
/// ```
pub fn define() -> Module {
    define_module("{{module_name}}")
        .prefix("/{{module_name}}")
        .get("/", handlers::index)
        .build()
}
