# Copy to `.env` and tweak. Loaded by `kick_rs::config::Config` with
# the `USERS_` prefix — every key gets that prefix stripped and
# lowercased before serde-deserialization.

USERS_DATABASE_URL=postgres://users:users@localhost:5432/users_api
USERS_BIND_ADDR=0.0.0.0:3000
RUST_LOG=info,users_api=debug,kick_rs=info
